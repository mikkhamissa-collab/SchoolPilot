{
  "manifest_version": 3,
  "name": "SchoolPilot",
  "version": "0.1.1",
  "description": "Connects your Teamie account to SchoolPilot so your AI study assistant knows your classes and grades.",
  "permissions": ["cookies", "storage", "activeTab", "scripting", "alarms"],
  "host_permissions": [
    "https://*.teamie.com/*",
    "https://teamie.com/*",
    "https://lms.asl.org/*",
    "https://schoolpilot-claw.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.teamie.com/*", "https://teamie.com/*", "https://lms.asl.org/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "externally_connectable": {
    "matches": ["https://schoolpilot.co/*", "https://*.schoolpilot.co/*", "http://localhost:3000/*"]
  },
  "web_accessible_resources": [
    {
      "resources": ["scrapers/*.js", "lib/*.js"],
      "matches": ["https://*.teamie.com/*", "https://teamie.com/*", "https://lms.asl.org/*"]
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
