# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-20250514

# Resend (email)
RESEND_API_KEY=re_...

# Encryption key for LMS credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIAL_ENCRYPTION_KEY=

# CORS
CORS_ORIGINS=["http://localhost:3000","https://schoolpilot.co"]

# Playwright
PLAYWRIGHT_HEADLESS=true

# Scheduler
DAILY_SYNC_HOUR=6

# Sentry (error tracking)
SENTRY_DSN=
ENVIRONMENT=production
